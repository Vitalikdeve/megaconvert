PORT=3000
CORS_ORIGIN=https://megaconvert.netlify.app
REDIS_URL=redis://redis:6379
STORAGE_MODE=s3
LOCAL_STORAGE_DIR=/data
RESEND_API_KEY=
RESEND_FROM=MegaConvert <no-reply@megaconvert.net>
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=megaconvert
WORKER_KEY_PUBLIC=
WORKER_KEY_PRIVATE=
RATE_LIMIT_UPLOADS_PER_MIN=30
RATE_LIMIT_JOBS_PER_MIN=20
ZK_SESSION_TTL_SEC=180
JOB_MAX_AGE_MS=900000
