VITE_API_BASE=
# Leave blank in local development and let Vite proxy /api to the local REST API.
# Production example:
# VITE_API_BASE=https://your-domain.example
VITE_WS_URL=
# Leave blank in local development and let Vite proxy /socket.io to the local realtime server.
# Production example:
# VITE_WS_URL=https://your-realtime.example
VITE_LOCAL_API_PROXY_TARGET=http://127.0.0.1:3000
VITE_LOCAL_SOCKET_PROXY_TARGET=http://127.0.0.1:4000
VITE_LIVEKIT_URL=ws://127.0.0.1:7880
# Production example for HTTPS frontends:
# VITE_LIVEKIT_URL=wss://your-livekit.example
VITE_TURNSTILE_SITE_KEY=0x4AAAAAACobtnPKcQ7ewkRH
