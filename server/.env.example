PORT=3000
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
SOCKET_PORT=4000
DATABASE_URL=postgresql://megaconvert:megaconvert@127.0.0.1:5432/megaconvert
REDIS_URL=redis://127.0.0.1:6379
STORAGE_MODE=s3
LOCAL_STORAGE_DIR=/data
RESEND_API_KEY=
RESEND_FROM=MegaConvert <no-reply@megaconvert.net>
S3_ENDPOINT=https://<accountid>.r2.cloudflarestorage.com
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=megaconvert
