{
  "buildCommand": "cd frontend && npm run build",
  "installCommand": "cd frontend && npm install",
  "outputDirectory": "frontend/dist",
  "framework": "vite",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://megaconvert-api.fly.dev/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
