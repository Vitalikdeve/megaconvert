{
  "name": "@megaconvert/design-system",
  "version": "0.1.0",
  "private": true,
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./styles.css": "./src/styles/index.css"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --external react --clean",
    "clean": "rimraf dist",
    "dev": "tsup src/index.ts --format esm,cjs --dts --external react --watch",
    "lint": "eslint .",
    "test": "vitest run --config ../../vitest.package.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "react": "^19.2.0"
  },
  "peerDependencies": {
    "react-dom": "^19.2.0"
  }
}
