NODE_ENV=development
APP_VERSION=0.1.0
APP_COMMIT_SHA=
LOG_LEVEL=info
API_GLOBAL_PREFIX=
HOST=0.0.0.0
PORT=4000
PUBLIC_ORIGIN=http://localhost:4000
AUTH_WEB_BASE_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000
REQUEST_ID_HEADER=x-correlation-id
TRUST_PROXY=false
SECURITY_HEADERS_ENABLED=true
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_MAX=120
RATE_LIMIT_GLOBAL_WINDOW_SECONDS=60
RATE_LIMIT_ALLOW_LIST=
REALTIME_EVENTS_CHANNEL=megaconvert:realtime:events
AUTH_GOOGLE_CLIENT_ID=
AUTH_GOOGLE_CLIENT_SECRET=
AUTH_GOOGLE_DISCOVERY_URL=https://accounts.google.com/.well-known/openid-configuration
AUTH_ACCESS_TOKEN_AUDIENCE=megaconvert-web
AUTH_ACCESS_COOKIE_NAME=mc_access
AUTH_ACCESS_TOKEN_SECRET=replace-with-a-strong-random-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=300
AUTH_REFRESH_COOKIE_NAME=mc_refresh
AUTH_REFRESH_TOKEN_TTL_DAYS=30
AUTH_STATE_COOKIE_NAME=mc_auth_state
AUTH_STATE_COOKIE_TTL_SECONDS=600
AUTH_STATE_SIGNING_SECRET=replace-with-a-different-strong-random-secret
DATABASE_URL=postgresql://megaconvert:megaconvert@localhost:5432/megaconvert
DATABASE_APPLICATION_NAME=megaconvert-api
DATABASE_POOL_MAX=20
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_SSL_MODE=disable
RUN_MIGRATIONS_ON_BOOT=false
SEED_HOOKS_ENABLED=false
REDIS_URL=
REDIS_KEY_PREFIX=megaconvert:api:
AUDIT_PERSISTENCE_ENABLED=false
SHUTDOWN_GRACE_PERIOD_MS=10000
