NODE_ENV=development
APP_VERSION=0.1.0
APP_COMMIT_SHA=
LOG_LEVEL=info
HOST=0.0.0.0
PORT=4010
PUBLIC_ORIGIN=http://localhost:4010
REQUEST_ID_HEADER=x-correlation-id
CORS_ORIGINS=http://localhost:3000
AUTH_ACCESS_TOKEN_AUDIENCE=megaconvert-web
AUTH_ACCESS_COOKIE_NAME=mc_access
AUTH_ACCESS_TOKEN_SECRET=replace-with-a-strong-random-secret
DATABASE_URL=postgresql://megaconvert:megaconvert@localhost:5432/megaconvert
DATABASE_APPLICATION_NAME=megaconvert-realtime
DATABASE_POOL_MAX=8
DATABASE_CONNECTION_TIMEOUT_MS=5000
DATABASE_IDLE_TIMEOUT_MS=30000
DATABASE_STATEMENT_TIMEOUT_MS=15000
DATABASE_SSL_MODE=disable
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=megaconvert:realtime:
REALTIME_EVENTS_CHANNEL=megaconvert:realtime:events
USER_PRESENCE_TTL_SECONDS=70
TYPING_TTL_SECONDS=8
