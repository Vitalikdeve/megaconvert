{
  "name": "@megaconvert/greenfield",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "pnpm build:packages",
    "dev": "turbo run dev --parallel --filter=@megaconvert/api --filter=@megaconvert/realtime --filter=@megaconvert/worker --filter=@megaconvert/web --filter=@megaconvert/config --filter=@megaconvert/contracts --filter=@megaconvert/shared-kernel --filter=@megaconvert/server-kit --filter=@megaconvert/client-sdk --filter=@megaconvert/database --filter=@megaconvert/design-system --filter=@megaconvert/testing",
    "dev:infra": "docker compose -f infra/docker/compose.local.yml up -d",
    "dev:infra:down": "docker compose -f infra/docker/compose.local.yml down -v",
    "db:migrate": "pnpm --filter @megaconvert/database db:migrate",
    "db:seed": "pnpm --filter @megaconvert/database db:seed",
    "build": "turbo run build",
    "build:packages": "turbo run build --filter=./packages/*",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "clean": "turbo run clean && rimraf node_modules .turbo apps/*/dist packages/*/dist apps/web/.next coverage"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@next/eslint-plugin-next": "^16.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.5.2",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.35.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.4.0",
    "jest": "^30.1.3",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "tsup": "^8.5.0",
    "tsx": "^4.20.5",
    "turbo": "^2.5.6",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.43.0",
    "vitest": "^3.2.4"
  }
}
