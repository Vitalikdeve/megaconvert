{
  "expo": {
    "name": "MegaConvert Business",
    "slug": "megaconvert-business",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "megaconvert-business",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#060B14"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Нужно для загрузки аватара профиля.",
        "NSCameraUsageDescription": "Нужно для сканирования QR-кодов контактов и видеозвонков.",
        "NSMicrophoneUsageDescription": "Нужно для голосовых и видеозвонков."
      }
    },
    "android": {
      "package": "com.megaconvert.business",
      "adaptiveIcon": {
        "backgroundColor": "#060B14",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      [
        "expo-camera",
        {
          "cameraPermission": "Разрешите доступ к камере для сканирования QR-кодов контактов."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5c7b1d42-94ab-413b-b229-5a7c5c5fa89d"
      }
    },
    "owner": "vitalikzelenkoplay"
  }
}
