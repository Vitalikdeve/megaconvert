NODE_ENV=production

# public origins
CORS_ORIGIN=https://chat.example.com
NEXT_PUBLIC_API_BASE_URL=https://api.example.com
NEXT_PUBLIC_SOCKET_URL=https://rt.example.com
NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# backend runtime
TRUST_PROXY=true
LOG_LEVEL=info
RATE_LIMIT_MAX=1200
RATE_LIMIT_TIME_WINDOW=1 minute

# externally published ports
API_PORT=4000
REALTIME_PORT=4001

# postgres
POSTGRES_DB=messenger
POSTGRES_USER=messenger
POSTGRES_PASSWORD=replace-with-long-random-password
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=300
POSTGRES_SHARED_BUFFERS=512MB
DATABASE_URL=postgres://messenger:replace-with-long-random-password@postgres:5432/messenger

# redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# object storage
S3_PORT=9000
S3_CONSOLE_PORT=9001
S3_ENDPOINT=http://object-storage:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=messenger
S3_SECRET_KEY=replace-with-long-random-secret
S3_BUCKET=messenger-media
S3_FORCE_PATH_STYLE=true
