NODE_ENV=development

# web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_SOCKET_URL=http://localhost:4001
NEXT_PUBLIC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302

# backend runtime
CORS_ORIGIN=http://localhost:3000
TRUST_PROXY=false
LOG_LEVEL=debug
RATE_LIMIT_MAX=600
RATE_LIMIT_TIME_WINDOW=1 minute

# api / realtime published ports
API_PORT=4000
REALTIME_PORT=4001

# postgres
POSTGRES_DB=messenger
POSTGRES_USER=messenger
POSTGRES_PASSWORD=messenger
POSTGRES_PORT=5432
POSTGRES_MAX_CONNECTIONS=250
POSTGRES_SHARED_BUFFERS=256MB
DATABASE_URL=postgres://messenger:messenger@localhost:5432/messenger

# redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# object storage
S3_PORT=9000
S3_CONSOLE_PORT=9001
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=messenger
S3_SECRET_KEY=change-me-in-production
S3_BUCKET=messenger-media
S3_FORCE_PATH_STYLE=true
